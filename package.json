{
  "name": "opensigil-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "build:cli": "cd packages/opensigil && npm run build",
    "build:all": "npm run build:cli && npm run build"
  }
}
